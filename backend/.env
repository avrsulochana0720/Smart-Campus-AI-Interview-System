# MySQL Configuration (XAMPP Default)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_campus_interview

# OpenAI API Key (optional - only needed if you want to use OpenAI)
OPENAI_API_KEY=your-openai-api-key-here

# NLP Model Configuration
# Available options: spacy, nltk, transformers, sklearn
NLP_MODEL_TYPE=spacy
SPACY_MODEL=en_core_web_sm
NLTK_MODEL= punkt
TRANSFORMERS_MODEL=distilbert-base-uncased
TRANSFORMERS_TASK=text-classification

# Classification Configuration
CLASSIFICATION_TYPES=IMPACT,MOTIVE,SYSTEM
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7

# Ollama Configuration (Qwen — used for questions, evaluation)
OLLAMA_MODEL=qwen3:0.6b
OLLAMA_BASE_URL=http://localhost:11434

# Gemini Flash Configuration (used by report_agent for honest reports)
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyC--U1W_8seZgI5ObfJj34Lp9vA6_0AL6c
GEMINI_MODEL=gemini-2.0-flash
